server:
  host: 0.0.0.0                  # 监听地址：0.0.0.0=所有接口(局域网可达) / 127.0.0.1=仅本机
  port: 9517
  mode: release                  # debug / release

database:
  host: localhost
  port: 5432
  user: airgate
  password: ""                   # 必须修改！或设置环境变量 DB_PASSWORD
  dbname: airgate
  sslmode: disable

redis:
  host: localhost
  port: 6379
  password: ""                   # 或设置环境变量 REDIS_PASSWORD
  db: 0

jwt:
  secret: ""                     # 必须修改！或设置环境变量 JWT_SECRET
  expire_hour: 24

security:
  api_key_secret: ""             # 可选，API Key 加密密钥（hex 编码，≥64 字符）
                                 # 未配置时使用内置默认值；或设置环境变量 API_KEY_SECRET

plugins:
  dir: data/plugins
  dev: []
  # dev:
  #   - name: airgate-openai
  #     path: ../../airgate-openai/backend
